{
  "name": "anshelstore",
  "version": "1.0.0",
  "description": "anshelstore - storefront jasa (AI Chat Automation), top up game, dan dashboard dengan human takeover. Backend Node.js tanpa dependency eksternal.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npx tailwindcss -i ./public/css/input.css -o ./public/css/theme.css --minify",
    "dev": "npx tailwindcss -i ./public/css/input.css -o ./public/css/theme.css --watch"
  },
  "dependencies": {
    "pg": "^8.11.3",
    "nodemailer": "^6.9.13",
    "sharp": "^0.33.3",
    "tailwindcss": "^3.4.3",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/container-queries": "^0.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
